# Local development environment for py-srv
# Copy to py-srv/.env (git-ignored) and fill in values.

# Disable JWT validation for local testing (never set in production)
SKIP_AUTH=true

# Use in-memory store instead of HANA (quick smoke test without DB)
# USE_IN_MEMORY_REPO=true

# DSP API credentials (on CF these come from the dsp-credentials UPS via VCAP_SERVICES)
DSP_HOSTNAME=https://<tenant>.eu30.hcs.cloud.sap
DSP_CLIENT_ID=sb-<xsappname>!t<instance>
DSP_CLIENT_SECRET=<client-secret>
DSP_AUTH_URL=https://<tenant>.authentication.eu30.hana.ondemand.com
DSP_SIMULATE=false

# DSP HANA cross-schema access (on CF these come from the dsp-hana UPS via VCAP_SERVICES)
DSP_HANA_HOST=<uuid>.hana.prod-eu30.hanacloud.ondemand.com
DSP_HANA_PORT=443
DSP_HANA_USER=DWCDBUSER#<schema>
DSP_HANA_PASSWORD=<password>

# ── IBP Integration (Application Jobs via OData) ──
# IBP_HOST=https://<tenant>-api.scmibp1.ondemand.com
# IBP_USER=<communication-user>
# IBP_PASSWORD=<password>
# IBP_VERIFY_SSL=true

# ── SAC Integration (Multi Actions via REST) ──
# SAC_HOST=https://<tenant>.<region>.sapanalytics.cloud
# SAC_TOKEN_URL=https://<tenant>.authentication.<region>.hana.ondemand.com/oauth/token
# SAC_CLIENT_ID=sb-<xsappname>!b<instance>|client!b<id>
# SAC_CLIENT_SECRET=<client-secret>
# SAC_VERIFY_SSL=true
