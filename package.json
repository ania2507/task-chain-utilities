{
  "name": "task-chain-utilities",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2.8.0",
    "@sap/cds": "^9",
    "@sap/hana-client": "^2.28.17",
    "@sap/hdi-deploy": "^5.6.0",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds-dk": "^9.9.0",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "dev": "bash scripts/dev-local.sh",
    "start": "cds-serve",
    "watch-webapp": "cds watch --open webapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy task-chain-utilities --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build",
    "deploy": "cf deploy mta_archives/task-chain-utilities_1.0.0.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "database": ":memory:"
          }
        }
      },
      "[hybrid]": {
        "auth": "xsuaa"
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "html5-repo": true,
      "destinations": true,
      "workzone": true
    }
  },
  "sapux": [
    "app/webapp",
    "app/skipoverrides",
    "app/monitoring"
  ]
}
