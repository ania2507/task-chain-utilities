{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/?odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.admin",
      "csrfProtection": true
    },
    {
      "source": "^/?v1/(.*)$",
      "target": "/v1/$1",
      "destination": "py-srv-api",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.admin"
    },
    {
      "source": "^(.*)$",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.admin",
      "target": "$1"
    }
  ]
}
