{
  "_version": "1.82.0",
  "sap.app": {
    "id": "skipoverrides",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "odata/v4/services/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "SkipOverrides-manage": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "SkipOverrides",
          "action": "manage",
          "title": "{{appTitle}}",
          "icon": "sap-icon://step"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "skipoverrides.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "SkipOverrideList",
          "target": "SkipOverrideList"
        },
        {
          "pattern": "SkipOverride({key}):?query:",
          "name": "SkipOverrideObjectPage",
          "target": "SkipOverrideObjectPage"
        }
      ],
      "targets": {
        "SkipOverrideList": {
          "type": "Component",
          "id": "SkipOverrideList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/SkipOverride",
              "variantManagement": "Page",
              "hideFilterBar": true,
              "navigation": {
                "SkipOverride": {
                  "detail": {
                    "route": "SkipOverrideObjectPage"
                  }
                }
              },
              "initialLoad": "Enabled",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "SkipOverrideObjectPage": {
          "type": "Component",
          "id": "SkipOverrideObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/SkipOverride"
            }
          }
        }
      }
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "taskchainutilities.service"
  }
}
