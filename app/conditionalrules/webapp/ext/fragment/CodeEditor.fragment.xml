<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:codeeditor="sap.ui.codeeditor">

    <VBox id="_IDGenVBox1" class="sapUiSmallMargin" width="100%">
        <codeeditor:CodeEditor
            id="pythonCodeEditor"
            height="400px"
            width="100%"
            value="{Rule}"
            type="python"
            syntaxHints="true"
            lineNumbers="true"
            editable="{= ${ui>/editMode} === 'Editable'}"/>
        <HBox id="_IDGenHBox" class="sapUiSmallMarginTop" justifyContent="Start">
            <Button id="btnValidateRule"
                text="Validate Syntax"
                icon="sap-icon://syntax"
                type="Emphasized"
                press=".extension.conditionalrules.ext.controller.ObjectPageExt.onValidateRule"
                class="sapUiSmallMarginEnd"/>
            <Button id="btnTestRule"
                text="Test Rule"
                icon="sap-icon://play"
                type="Accept"
                press=".extension.conditionalrules.ext.controller.ObjectPageExt.onTestRule"/>
        </HBox>
    </VBox>
    
</core:FragmentDefinition>
