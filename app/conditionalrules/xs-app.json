{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.admin",
      "csrfProtection": false
    },
    {
      "source": "^/v1/(.*)$",
      "target": "/v1/$1",
      "destination": "py-srv-api",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.admin",
      "csrfProtection": false
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.admin"
    }
  ]
}
