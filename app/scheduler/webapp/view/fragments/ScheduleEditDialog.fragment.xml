<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    <Dialog title="{i18n>detail.title}" contentWidth="640px">
        <content>
            <f:SimpleForm editable="true" layout="ColumnLayout"
                          columnsM="1" columnsL="1" columnsXL="1" labelSpanXL="3" labelSpanL="3">
                <f:content>
                    <Label text="{i18n>col.name}" required="true"/>
                    <Input value="{edit>/name}"/>

                    <Label text="Description"/>
                    <TextArea value="{edit>/description}" rows="2"/>

                    <Label text="{i18n>col.target}" required="true"/>
                    <Select selectedKey="{edit>/targetType}">
                        <items>
                            <core:Item key="DSP" text="{i18n>target.DSP}"/>
                            <core:Item key="IBP" text="{i18n>target.IBP}"/>
                            <core:Item key="SAC" text="{i18n>target.SAC}"/>
                        </items>
                    </Select>

                    <Label text="DSP Space"/>
                    <Input value="{edit>/spaceId}"
                           enabled="{= ${edit>/targetType} === 'DSP' &amp;&amp; !${edit>/chainLocked} }"
                           editable="{= !${edit>/chainLocked} }"/>

                    <Label text="DSP Taskchain"/>
                    <Input value="{edit>/taskchain}"
                           enabled="{= ${edit>/targetType} === 'DSP' &amp;&amp; !${edit>/chainLocked} }"
                           editable="{= !${edit>/chainLocked} }"/>

                    <Label text="Job Template"/>
                    <Input value="{edit>/jobTemplate}" enabled="{= ${edit>/targetType} !== 'DSP' }"/>

                    <Label text="Parameters (JSON)"/>
                    <TextArea value="{edit>/parameters}" rows="3" growing="true"/>

                    <Label text="{i18n>col.cron}" required="true"/>
                    <Input value="{edit>/cronExpression}" placeholder="m h dom mon dow"/>

                    <Label text="{i18n>col.timezone}"/>
                    <Input value="{edit>/timezone}"/>

                    <Label text="{i18n>col.active}"/>
                    <Switch state="{edit>/isActive}"/>
                </f:content>
            </f:SimpleForm>

            <Toolbar>
                <Title text="{i18n>detail.previewTitle}" level="H4"/>
                <ToolbarSpacer/>
                <Button icon="sap-icon://show" text="{i18n>common.preview}" press=".onPreviewCron" busy="{preview>/busy}"/>
            </Toolbar>
            <List items="{preview>/next}">
                <StandardListItem title="{preview>}" icon="sap-icon://date-time"/>
            </List>
        </content>
        <beginButton><Button text="{i18n>common.save}"   type="Emphasized" press=".onSave"/></beginButton>
        <endButton>  <Button text="{i18n>common.cancel}"                  press=".onCloseDialog"/></endButton>
    </Dialog>
</core:FragmentDefinition>
