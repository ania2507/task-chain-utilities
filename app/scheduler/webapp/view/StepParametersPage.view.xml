<mvc:View
    controllerName="scheduler.controller.StepParametersPage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout">
    <f:DynamicPage id="stepParametersPage" busy="{edit>/busy}" toggleHeaderOnTitleClick="true" showFooter="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center">
                        <Button icon="sap-icon://nav-back" type="Transparent"
                                tooltip="{i18n>common.back}" press=".onNavBack"
                                class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <Title text="{= ${edit>/targetType} === 'IBP' ? ('IBP Job Parameters — ' + ${edit>/jobTemplate}) : ('Step Parameters — ' + ${edit>/taskchain}) }" wrapping="true"/>
                            <Text text="{= ${edit>/targetType} === 'IBP' ? 'Configure parameters per IBP job template step' : 'Each execution can carry its own step parameters' }"/>
                        </VBox>
                    </HBox>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <l:Splitter height="100%">
                <!-- LEFT: chain steps / IBP template steps list -->
                <Panel headerText="{= ${edit>/targetType} === 'IBP' ? 'IBP Job Template Steps' : 'Chain Steps (click to add params)' }"
                       width="auto" class="sapUiSmallMargin">
                    <layoutData>
                        <l:SplitterLayoutData size="360px"/>
                    </layoutData>
                    <content>
                        <List items="{edit>/steps}" mode="None"
                              noDataText="{= ${edit>/targetType} === 'IBP' ? 'No steps found in the IBP job template' : 'No steps available — the task chain may not have run yet' }">
                            <ObjectListItem
                                title="{edit>name}"
                                intro="{edit>order}"
                                type="Active"
                                press=".onStepPress">
                                <attributes>
                                    <ObjectAttribute text="{= ${edit>businessName} || ${edit>name} }"/>
                                    <ObjectAttribute text="{edit>description}" visible="{= !!${edit>description} }"/>
                                    <ObjectAttribute text="{ parts: [{path: 'edit>params'}, {path: 'edit>ibpSteps'}], formatter: '.formatStepParamCount' }"/>
                                </attributes>
                            </ObjectListItem>
                        </List>
                        <Text text="Select a step to see / edit its params"
                              class="sapUiSmallMargin"
                              visible="{= !!${edit>/steps}.length &amp;&amp; !${edit>/selectedStepId} }"/>
                    </content>
                </Panel>

                <!-- RIGHT: parameters of the selected step -->
                <Panel headerText="{= 'Parameters for: ' + (${edit>/selectedStepName} || '(no step selected)') }"
                       width="auto" class="sapUiSmallMargin">
                    <content>

                        <!-- CASE 0: step does not allow parameters (not an API call) -->
                        <MessageStrip text="Parameters are not allowed for this step: it is not an API call."
                                       type="Warning" showIcon="true" class="sapUiSmallMargin"
                                       visible="{= !!${edit>/selectedStepId} &amp;&amp; !!${edit>/selectedStepIsBlocked} }"/>

                        <!-- CASE 1: Regular DSP step — no IBP/SAC template detected -->
                        <VBox visible="{= !!${edit>/selectedStepId} &amp;&amp; !${edit>/selectedStepIsBlocked} &amp;&amp; !${edit>/ibpTemplateName} &amp;&amp; !${edit>/sacMultiActionId} }">
                            <Title text="Configured parameters:" level="H5" class="sapUiSmallMarginBottom"/>
                            <Table items="{edit>/selectedStepParams}" noDataText="No parameters yet">
                                <columns>
                                    <Column><Text text="Param Key"/></Column>
                                    <Column><Text text="Param Value"/></Column>
                                    <Column hAlign="Center" width="6rem"><Text text="Active"/></Column>
                                    <Column hAlign="End" width="7rem"><Text text=""/></Column>
                                </columns>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{edit>key}"/>
                                        <Text text="{edit>value}"/>
                                        <core:Icon src="{= ${edit>active} ? 'sap-icon://accept' : 'sap-icon://decline' }"
                                                   color="{= ${edit>active} ? '#2ecc71' : '#bdc3c7' }"/>
                                        <HBox justifyContent="End">
                                            <Button icon="sap-icon://edit" type="Transparent" press=".onEditParam" tooltip="Edit"/>
                                            <Button icon="sap-icon://delete" type="Reject" press=".onDeleteParam" tooltip="Delete"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </Table>
                            <Panel headerText="Add New Parameter" class="sapUiSmallMarginTop"
                                   expandable="true" expanded="true">
                                <content>
                                    <VBox class="sapUiSmallMargin">
                                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Param Key:" width="9rem"/>
                                            <Input value="{edit>/newParam/key}" width="20rem"/>
                                        </HBox>
                                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Param Value:" width="9rem"/>
                                            <Input value="{edit>/newParam/value}" width="20rem"/>
                                        </HBox>
                                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Active:" width="9rem"/>
                                            <CheckBox selected="{edit>/newParam/active}"/>
                                        </HBox>
                                        <HBox class="sapUiSmallMarginTop">
                                            <Button text="Confirm" type="Accept" icon="sap-icon://accept"
                                                    press=".onAddParam" class="sapUiTinyMarginEnd"/>
                                            <Button text="Cancel" press=".onResetNewParam"/>
                                        </HBox>
                                    </VBox>
                                </content>
                            </Panel>
                        </VBox>

                        <!-- CASE 2: API step → IBP/SAC template detected → edit sub-step params directly -->
                        <VBox visible="{= !!${edit>/selectedStepId} &amp;&amp; !${edit>/selectedStepIsBlocked} &amp;&amp; !!${edit>/ibpTemplateName} }"
                              busy="{edit>/ibpLoading}">
                            <HBox alignItems="Center" class="sapUiSmallMargin">
                                <Label text="Template:" width="7rem"/>
                                <Text text="{edit>/ibpTemplateName}" class="sapUiTinyMarginEnd"/>
                                <Button icon="sap-icon://refresh" type="Transparent"
                                        press=".onLoadIbpSteps" tooltip="Reload steps"
                                        class="sapUiTinyMarginBegin"/>
                            </HBox>
                            <l:Splitter height="480px">
                                <!-- Left: job template steps list -->
                                <Panel headerText="Job Template Steps" width="auto">
                                    <layoutData>
                                        <l:SplitterLayoutData size="340px"/>
                                    </layoutData>
                                    <List items="{edit>/ibpSteps}" mode="None"
                                          noDataText="{= ${edit>/ibpLoading} ? 'Loading...' : 'No steps found in IBP template' }">
                                        <StandardListItem
                                            title="{edit>name}"
                                            description="{edit>description}"
                                            info="{= (${edit>params}.length || 0) + ' params'}"
                                            infoState="{= ${edit>params}.length > 0 ? 'Success' : 'None'}"
                                            highlight="{= ${edit>name} === ${edit>/selectedIbpStepName} ? 'Information' : 'None' }"
                                            type="Active"
                                            press=".onIbpStepPress"/>
                                    </List>
                                </Panel>
                                <!-- Right: selected sub-step params + add form -->
                                <Panel headerText="{= ${edit>/selectedIbpStepName} ? ('Params: ' + ${edit>/selectedIbpStepName}) : '(select a step on the left)' }"
                                       width="auto">
                                    <VBox visible="{= !!${edit>/selectedIbpStepName} }" class="sapUiSmallMargin">
                                        <Table items="{edit>/selectedIbpStepParams}" noDataText="No parameters yet">
                                            <columns>
                                                <Column><Text text="Key"/></Column>
                                                <Column><Text text="Description"/></Column>
                                                <Column><Text text="Value"/></Column>
                                                <Column hAlign="Center" width="5rem"><Text text="Active"/></Column>
                                                <Column hAlign="End" width="6rem"><Text text=""/></Column>
                                            </columns>
                                            <ColumnListItem>
                                                <cells>
                                                    <Text text="{edit>key}"/>
                                                    <Text text="{edit>description}" class="sapUiSmallFontSize"/>
                                                    <Text text="{edit>value}"/>
                                                    <core:Icon src="{= ${edit>active} ? 'sap-icon://accept' : 'sap-icon://decline' }"
                                                               color="{= ${edit>active} ? '#2ecc71' : '#bdc3c7' }"/>
                                                    <HBox justifyContent="End">
                                                        <Button icon="sap-icon://edit" type="Transparent" press=".onEditIbpStepParam" tooltip="Edit"/>
                                                        <Button icon="sap-icon://delete" type="Reject" press=".onDeleteIbpStepParam" tooltip="Delete"/>
                                                    </HBox>
                                                </cells>
                                            </ColumnListItem>
                                        </Table>
                                        <HBox alignItems="Center" class="sapUiSmallMarginTop" wrap="Wrap">
                                            <Label text="Key:" width="4rem"/>
                                            <Input value="{edit>/newIbpParam/key}" width="12rem" placeholder="param key"/>
                                            <Button icon="sap-icon://value-help" type="Transparent"
                                                    press=".onIbpKeyValueHelp" tooltip="Match code — select from available IBP parameters"/>
                                            <Label text="Value:" width="4rem" class="sapUiTinyMarginBegin"/>
                                            <Input value="{edit>/newIbpParam/value}" width="12rem" placeholder="param value"/>
                                            <CheckBox selected="{edit>/newIbpParam/active}" text="Active" class="sapUiTinyMarginBegin"/>
                                            <Button text="Add" type="Accept" icon="sap-icon://add"
                                                    press=".onAddIbpStepParam" class="sapUiTinyMarginBegin"/>
                                            <Button text="Cancel" press=".onResetIbpNewParam" class="sapUiTinyMarginBegin"/>
                                        </HBox>
                                    </VBox>
                                </Panel>
                            </l:Splitter>
                        </VBox>

                        <!-- CASE 3: API step → SAC multi action detected → configure multi action parameters -->
                        <VBox visible="{= !!${edit>/selectedStepId} &amp;&amp; !${edit>/selectedStepIsBlocked} &amp;&amp; !!${edit>/sacMultiActionId} }">
                            <HBox alignItems="Center" class="sapUiSmallMargin">
                                <Label text="Multi Action:" width="7rem"/>
                                <Text text="{edit>/sacMultiActionId}" class="sapUiTinyMarginEnd"/>
                            </HBox>
                            <Title text="Configured parameters:" level="H5" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom"/>
                            <Table items="{edit>/selectedStepParams}" noDataText="No parameters yet" class="sapUiSmallMarginBeginEnd">
                                <columns>
                                    <Column><Text text="Parameter ID"/></Column>
                                    <Column><Text text="Value"/></Column>
                                    <Column hAlign="Center" width="6rem"><Text text="Active"/></Column>
                                    <Column hAlign="End" width="7rem"><Text text=""/></Column>
                                </columns>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{edit>key}"/>
                                        <Text text="{edit>value}"/>
                                        <core:Icon src="{= ${edit>active} ? 'sap-icon://accept' : 'sap-icon://decline' }"
                                                   color="{= ${edit>active} ? '#2ecc71' : '#bdc3c7' }"/>
                                        <HBox justifyContent="End">
                                            <Button icon="sap-icon://edit" type="Transparent" press=".onEditParam" tooltip="Edit"/>
                                            <Button icon="sap-icon://delete" type="Reject" press=".onDeleteParam" tooltip="Delete"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </Table>
                            <Panel headerText="Add New Parameter" class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd"
                                   expandable="true" expanded="true">
                                <content>
                                    <VBox class="sapUiSmallMargin">
                                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Parameter ID:" width="9rem"/>
                                            <Input value="{edit>/newParam/key}" width="20rem" placeholder="e.g. TargetVersion"/>
                                        </HBox>
                                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Value:" width="9rem"/>
                                            <Input value="{edit>/newParam/value}" width="20rem" placeholder="e.g. public.FCST_Sim5, or JSON for advanced cases"/>
                                        </HBox>
                                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Active:" width="9rem"/>
                                            <CheckBox selected="{edit>/newParam/active}"/>
                                        </HBox>
                                        <HBox class="sapUiSmallMarginTop">
                                            <Button text="Confirm" type="Accept" icon="sap-icon://accept"
                                                    press=".onAddParam" class="sapUiTinyMarginEnd"/>
                                            <Button text="Cancel" press=".onResetNewParam"/>
                                        </HBox>
                                    </VBox>
                                </content>
                            </Panel>
                        </VBox>

                        <Text text="Select a step from the list on the left"
                              class="sapUiSmallMargin"
                              visible="{= !${edit>/selectedStepId} }"/>
                    </content>
                </Panel>
            </l:Splitter>
        </f:content>

        <f:footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="{i18n>common.cancel}" press=".onNavBack"/>
                <Button text="{i18n>common.save}" type="Emphasized" press=".onSave"/>
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>
