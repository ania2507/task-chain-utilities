<mvc:View
    controllerName="scheduler.controller.CustomCalendarPage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified">
    <f:DynamicPage id="customCalendarPage" busy="{edit>/busy}" toggleHeaderOnTitleClick="true" showFooter="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center">
                        <Button icon="sap-icon://nav-back" type="Transparent"
                                tooltip="{i18n>common.back}" press=".onNavBack"
                                class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <Title text="Task Chain - {edit>/taskchain}" wrapping="true"/>
                            <Text text="{ path: 'edit>/name', formatter: '.formatBusinessName' }"/>
                        </VBox>
                    </HBox>
                </f:heading>
                <f:snappedHeading>
                    <HBox alignItems="Center">
                        <Button icon="sap-icon://nav-back" type="Transparent"
                                tooltip="{i18n>common.back}" press=".onNavBack"
                                class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <Title text="Task Chain - {edit>/taskchain}" wrapping="true"/>
                            <Text text="{ path: 'edit>/name', formatter: '.formatBusinessName' }"/>
                        </VBox>
                    </HBox>
                </f:snappedHeading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="false">
                <HBox alignItems="Center" wrap="Wrap"
                      class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom">

                    <!-- Calendar schedule -->
                    <HBox alignItems="Center" class="sapUiLargeMarginEnd">
                        <core:Icon
                            src="sap-icon://date-time"
                            size="2.5rem"
                            color="{= ${edit>/activeCount} > 0 ? '#0a6ed1' : '#9E9E9E' }"
                            class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <ObjectStatus
                                text="{i18n>calendar.scheduled}"
                                state="{= ${edit>/activeCount} > 0 ? 'Information' : 'None' }"
                                inverted="true"
                                class="sapUiTinyMarginBottom"/>
                            <Text text="{i18n>calendar.intro}"/>
                            <Text text="{i18n>calendar.format}"/>
                        </VBox>
                    </HBox>

                    <core:HTML content="&lt;div style='width:1px;height:3.5rem;background:#e0e0e0;margin-right:1.5rem'&gt;&lt;/div&gt;"/>

                    <!-- Active entries -->
                    <VBox class="sapUiMediumMarginEnd">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://list" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="{i18n>calendar.activeEntries}"/>
                        </HBox>
                        <Text text="{= ${edit>/activeCount} + ' / ' + ${edit>/totalCount} }"/>
                    </VBox>

                    <!-- Next run -->
                    <VBox class="sapUiMediumMarginEnd" visible="{= !!${edit>/nextRunLabel} }">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://date-time" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="{i18n>onDemand.nextRun}"/>
                        </HBox>
                        <Text text="{edit>/nextRunLabel}"/>
                    </VBox>

                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <l:Splitter class="splitter-auto-height">

                <!-- LEFT: Custom Calendar configuration -->
                <Panel headerText="{i18n>calendar.title}" class="sapUiNoMargin">
                    <content>
                        <VBox class="sapUiMediumMarginTopBottom sapUiMediumMarginBeginEnd">
                            <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                <u:FileUploader
                                    id="customCalendarPageFileUploader"
                                    name="calendar"
                                    buttonOnly="true"
                                    buttonText="{i18n>calendar.upload}"
                                    fileType="xlsx,xls,csv"
                                    style="Emphasized"
                                    icon="sap-icon://upload"
                                    iconOnly="false"
                                    change=".onCalendarFileSelect"/>
                                <Button text="{i18n>calendar.downloadTemplate}"
                                        icon="sap-icon://download"
                                        press=".onDownloadCalendarTemplate"
                                        class="sapUiTinyMarginBegin"/>
                                <Button text="{i18n>calendar.addEntry}"
                                        icon="sap-icon://add"
                                        press=".onAddCalendarEntry"
                                        class="sapUiTinyMarginBegin"/>
                            </HBox>

                            <ObjectStatus
                                text="{edit>/calendarFileStatus}"
                                state="{= ${edit>/calendarEntries}.length > 0 ? 'Success' : 'None' }"
                                class="sapUiTinyMarginBottom"
                                visible="{= !!${edit>/calendarFileStatus} }"/>

                            <Text text="{i18n>calendar.noFile}"
                                  class="sapUiSmallMarginBegin"
                                  visible="{= !${edit>/calendarFileStatus} &amp;&amp; ${edit>/calendarEntries}.length === 0 }"/>

                            <Table id="calendarEntriesTable"
                                   items="{edit>/calendarEntries}"
                                   mode="None"
                                   growing="true"
                                   growingThreshold="50"
                                   visible="{= ${edit>/calendarEntries}.length > 0 }"
                                   noDataText="{i18n>calendar.noEntries}">
                                <headerToolbar>
                                    <Toolbar>
                                        <Title text="{ path: 'edit>/taskchain', formatter: '.formatCalendarEntriesTitle' }" level="H4"/>
                                        <ToolbarSpacer/>
                                        <Label text="{i18n>calendar.dateFrom}" labelFor="dateFromFilter" class="sapUiTinyMarginEnd"/>
                                        <DatePicker id="dateFromFilter"
                                                    value="{edit>/filterDateFrom}"
                                                    valueFormat="yyyy-MM-dd"
                                                    displayFormat="medium"
                                                    width="10rem"
                                                    change=".onDateFilterChange"
                                                    class="sapUiTinyMarginEnd"/>
                                        <Label text="{i18n>calendar.dateTo}" labelFor="dateToFilter" class="sapUiTinyMarginEnd"/>
                                        <DatePicker id="dateToFilter"
                                                    value="{edit>/filterDateTo}"
                                                    valueFormat="yyyy-MM-dd"
                                                    displayFormat="medium"
                                                    width="10rem"
                                                    change=".onDateFilterChange"
                                                    class="sapUiSmallMarginEnd"/>
                                        <Label text="{i18n>calendar.showPast}" labelFor="showPastEntriesSwitch" class="sapUiTinyMarginEnd"/>
                                        <Switch id="showPastEntriesSwitch"
                                                state="{edit>/showPastEntries}"
                                                change=".onTogglePastEntries"/>
                                    </Toolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>calendar.col.date}"/></Column>
                                    <Column><Text text="{i18n>calendar.col.time}"/></Column>
                                    <Column hAlign="Center"><Text text="{i18n>calendar.col.active}"/></Column>
                                    <Column><Text text="{i18n>calendar.col.details}"/></Column>
                                    <Column><Text text="{i18n>calendar.col.runStatus}"/></Column>
                                    <Column hAlign="End" width="22rem"><Text text=""/></Column>
                                </columns>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{edit>dateLabel}"/>
                                        <Text text="{edit>time}"/>
                                        <core:Icon src="sap-icon://accept"
                                                   color="{= ${edit>active} ? 'Positive' : 'Neutral' }"
                                                   visible="{edit>active}"/>
                                        <Text text="{edit>details}" maxLines="2"/>
                                        <HBox alignItems="Center">
                                            <core:Icon
                                                src="{= ${edit>runStatus} === 'success' ? 'sap-icon://sys-enter-2' : ${edit>runStatus} === 'error' ? 'sap-icon://sys-cancel-2' : ${edit>runStatus} === 'running' ? 'sap-icon://pending' : ${edit>runStatus} === 'skipped' ? 'sap-icon://step' : '' }"
                                                color="{= ${edit>runStatus} === 'success' ? '#107E3E' : ${edit>runStatus} === 'error' ? '#BB0000' : ${edit>runStatus} === 'running' ? '#0a6ed1' : '#9E9E9E' }"
                                                visible="{= !!${edit>runStatus} }"
                                                class="sapUiTinyMarginEnd"/>
                                            <Text text="{= !!${edit>runStatus} ? ${edit>runStatus} : ${i18n>calendar.runStatus.none} }"/>
                                        </HBox>
                                        <HBox justifyContent="End" alignItems="Center">
                                            <Button text="{i18n>onDemand.configureSteps}"
                                                    icon="sap-icon://settings"
                                                    type="Emphasized"
                                                    press=".onCalendarConfigureRowParams"
                                                    class="sapUiTinyMarginEnd"/>
                                            <Button icon="sap-icon://edit"
                                                    tooltip="{i18n>calendar.edit}"
                                                    type="Transparent"
                                                    visible="{= !${edit>isPast} }"
                                                    press=".onEditCalendarEntry"/>
                                            <Button icon="sap-icon://delete"
                                                    tooltip="{i18n>calendar.remove}"
                                                    type="Transparent"
                                                    press=".onRemoveCalendarEntry"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </Table>
                        </VBox>
                    </content>
                </Panel>

                <!-- RIGHT: Last Run -->
                <Panel class="sapUiNoMargin">
                    <layoutData>
                        <l:SplitterLayoutData size="280px" resizable="false"/>
                    </layoutData>
                    <VBox class="sapUiMediumMarginTopBottom sapUiMediumMarginBeginEnd">
                        <Title text="Last Run" level="H5" class="sapUiMediumMarginBottom"/>

                        <VBox visible="{= !!${edit>/lastRunAt} }">
                            <VBox class="sapUiSmallMarginBottom">
                                <Label text="Date and time" design="Bold"/>
                                <Text text="{ path: 'edit>/lastRunAt', formatter: '.formatDateTime' }"/>
                            </VBox>
                            <VBox>
                                <Label text="Status" design="Bold" class="sapUiTinyMarginBottom"/>
                                <HBox alignItems="Center">
                                    <core:Icon
                                        src="{= ${edit>/lastRunStatus} === 'completed' || ${edit>/lastRunStatus} === 'success' ? 'sap-icon://sys-enter-2' : ${edit>/lastRunStatus} === 'error' ? 'sap-icon://sys-cancel-2' : 'sap-icon://pending' }"
                                        size="1.25rem"
                                        color="{= ${edit>/lastRunStatus} === 'completed' || ${edit>/lastRunStatus} === 'success' ? '#107E3E' : ${edit>/lastRunStatus} === 'error' ? '#BB0000' : '#9E9E9E' }"
                                        class="sapUiTinyMarginEnd"/>
                                    <Text text="{edit>/lastRunStatus}"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <Text text="No runs yet." visible="{= !${edit>/lastRunAt} }"/>
                    </VBox>
                </Panel>

            </l:Splitter>
        </f:content>

        <f:footer>
            <OverflowToolbar>
                <Button text="{i18n>calendar.deleteAll}"
                        icon="sap-icon://delete"
                        type="Reject"
                        enabled="{= ${edit>/visibleEntriesCount} > 0 }"
                        press=".onDeleteAllEntries"/>
                <ToolbarSpacer/>
                <Button text="{i18n>common.cancel}" press=".onNavBack"/>
                <Button text="{i18n>calendar.confirm}"
                        type="Emphasized"
                        enabled="{= ${edit>/calendarEntries}.length > 0 }"
                        press=".onConfirmCustomCalendar"/>
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>
