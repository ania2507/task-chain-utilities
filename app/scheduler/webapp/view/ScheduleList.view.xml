<mvc:View
    controllerName="scheduler.controller.ScheduleList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">
    <f:DynamicPage id="scheduleListPage" fitContent="true" busy="{page>/busy}">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VariantManagement id="variantManagement" selectedKey="standard">
                        <items>
                            <VariantItem key="standard" title="Standard" rename="false" remove="false"/>
                        </items>
                    </VariantManagement>
                </f:heading>
                <f:snappedContent>
                    <HBox wrap="Wrap">
                        <Label text="{i18n>common.search}" class="sapUiTinyMarginEnd"/>
                        <Text text="{page>/searchQuery}"/>
                    </HBox>
                </f:snappedContent>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox alignItems="Center" wrap="Wrap"
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop sapUiTinyMarginEnd">

                    <!-- Total task chains -->
                    <HBox alignItems="Center" class="sapUiLargeMarginEnd">
                        <core:Icon
                            src="sap-icon://chain-link"
                            size="2.5rem"
                            color="#0a6ed1"
                            class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <ObjectStatus
                                text="{i18n>list.summary.total}"
                                state="Information"
                                inverted="true"
                                class="sapUiTinyMarginBottom"/>
                            <Text text="{page>/summary/total}"/>
                        </VBox>
                    </HBox>

                    <core:HTML content="&lt;div style='width:1px;height:3.5rem;background:#e0e0e0;margin-right:1.5rem'&gt;&lt;/div&gt;"/>

                    <!-- Scheduled -->
                    <VBox class="sapUiMediumMarginEnd">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://appointment-2" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="{i18n>list.summary.scheduled}"/>
                        </HBox>
                        <Text text="{page>/summary/scheduled}"/>
                    </VBox>

                    <!-- Not scheduled -->
                    <VBox class="sapUiMediumMarginEnd">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://list" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="{i18n>list.summary.notScheduled}"/>
                        </HBox>
                        <Text text="{page>/summary/notScheduled}"/>
                    </VBox>

                    <!-- Paused -->
                    <VBox class="sapUiMediumMarginEnd" visible="{= ${page>/summary/paused} > 0 }">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://pause" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="{i18n>list.summary.paused}"/>
                        </HBox>
                        <Text text="{page>/summary/paused}"/>
                    </VBox>

                    <core:HTML content="&lt;div style='width:1px;height:3.5rem;background:#e0e0e0;margin-right:1.5rem'&gt;&lt;/div&gt;"/>

                    <!-- Search -->
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="{i18n>common.search}" labelFor="taskchainSearchField"/>
                        <SearchField id="taskchainSearchField"
                            placeholder="{i18n>list.searchPlaceholder}"
                            width="250px"
                            value="{page>/searchQuery}"
                            search=".onSearchTaskchains"
                            liveChange=".onSearchTaskchains"/>
                    </VBox>

                    <!-- Space filter -->
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="{i18n>list.filter.space}" labelFor="spaceFilterSelect"/>
                        <Select id="spaceFilterSelect"
                                width="160px"
                                selectedKey="{page>/filterSpace}"
                                change=".onFilterChange"
                                items="{path: 'page>/spaceOptions', templateShareable: false}">
                            <core:Item key="{page>key}" text="{page>text}"/>
                        </Select>
                    </VBox>

                    <!-- Status filter -->
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="{i18n>list.filter.status}" labelFor="statusFilterSelect"/>
                        <Select id="statusFilterSelect"
                                width="160px"
                                selectedKey="{page>/filterStatus}"
                                change=".onFilterChange">
                            <core:Item key="all" text="{i18n>list.filter.statusAll}"/>
                            <core:Item key="scheduled" text="{i18n>list.summary.scheduled}"/>
                            <core:Item key="notScheduled" text="{i18n>list.summary.notScheduled}"/>
                            <core:Item key="paused" text="{i18n>list.summary.paused}"/>
                        </Select>
                    </VBox>

                    <!-- Type filter -->
                    <VBox>
                        <Label text="{i18n>list.filter.type}" labelFor="typeFilterSelect"/>
                        <Select id="typeFilterSelect"
                                width="160px"
                                selectedKey="{page>/filterType}"
                                change=".onFilterChange">
                            <core:Item key="all" text="{i18n>list.filter.typeAll}"/>
                            <core:Item key="trafficLights" text="{i18n>list.filter.trafficLights}"/>
                            <core:Item key="onDemand" text="{i18n>list.filter.onDemand}"/>
                            <core:Item key="customCalendar" text="{i18n>list.filter.customCalendar}"/>
                            <core:Item key="dsp" text="{i18n>list.filter.dsp}"/>
                        </Select>
                    </VBox>

                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table id="taskchainsTable"
                   items="{ path: 'page>/rows', sorter: { path: 'spaceId' } }"
                   growing="true"
                   growingThreshold="100"
                   mode="None"
                   noDataText="{i18n>list.empty}">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{= ${page>/filteredCount} + ' Task Chains'}" level="H5"/>
                        <ToolbarSpacer/>
                        <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>common.refresh}"/>
                        <Button icon="sap-icon://add" type="Emphasized" text="{i18n>common.addTaskchain}" press=".onAddTaskchain"/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="{i18n>col.space}"/></Column>
                    <Column><Text text="{i18n>col.taskchain}"/></Column>
                    <Column><Text text="{i18n>col.schedule}"/></Column>
                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>col.nextRun}"/></Column>
                    <Column hAlign="Center"><Text text="{i18n>col.type}"/></Column>
                    <Column hAlign="Center"><Text text="{i18n>col.action}"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{page>spaceId}"/>
                            <ObjectIdentifier title="{page>name}" text="{page>businessName}"/>

                            <VBox>
                                <ObjectStatus text="{i18n>status.scheduled}" state="Success"
                                              icon="sap-icon://accept"
                                              visible="{= !!${page>hasInfo} }"/>
                                <ObjectStatus text="{i18n>status.notScheduled}" state="None"
                                              visible="{= !${page>hasInfo} }"/>
                            </VBox>

                            <VBox>
                                <ObjectStatus text="Paused" state="Warning" icon="sap-icon://pause"
                                              visible="{= !!${page>isPaused} }"/>
                                <Text text="{ path: 'page>nextRunAt', formatter: '.formatDate' }"
                                      visible="{= ${page>hasInfo} &amp;&amp; !${page>isPaused} }"/>
                            </VBox>

                            <ObjectStatus
                                text="{page>typeLabel}"
                                state="{page>typeState}"
                                icon="{page>typeIcon}"
                                visible="{= ${page>hasInfo} }"/>

                            <HBox justifyContent="Center" alignItems="Center">
                                <HBox width="2.5rem" justifyContent="Center">
                                    <Button icon="sap-icon://activity-items"
                                            type="Emphasized"
                                            press=".onScheduleTaskchain"
                                            tooltip="{i18n>tip.createSchedule}"
                                            visible="{= !!${page>schedulesLoaded} &amp;&amp; !${page>hasEntries} }"/>
                                    <Button icon="sap-icon://edit"
                                            type="Emphasized"
                                            press=".onDirectEditSchedule"
                                            tooltip="{i18n>common.edit}"
                                            visible="{= !!${page>hasEntries} &amp;&amp; !${page>hasDspSchedule} }"/>
                                </HBox>
                                <Button icon="sap-icon://decline"
                                        type="Transparent"
                                        tooltip="{i18n>common.remove}"
                                        press=".onRemoveRow"/>
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>
