<mvc:View
    controllerName="scheduler.controller.TrafficLightsPage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout">
    <f:DynamicPage id="trafficLightsPage" busy="{edit>/busy}" toggleHeaderOnTitleClick="false" showFooter="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center">
                        <Button icon="sap-icon://nav-back" type="Transparent"
                                tooltip="{i18n>common.back}" press=".onNavBack"
                                class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <Title text="{edit>/taskchain}" wrapping="true"/>
                            <Text text="{ path: 'edit>/name', formatter: '.formatBusinessName' }"/>
                        </VBox>
                    </HBox>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <l:Splitter height="100%">

                <!-- LEFT: traffic light -->
                <Panel width="auto" class="sapUiSmallMargin">
                    <layoutData>
                        <l:SplitterLayoutData size="240px" resizable="false"/>
                    </layoutData>
                    <VBox alignItems="Center" class="sapUiLargeMarginTopBottom sapUiMediumMarginBeginEnd">
                        <Title text="Initial State" level="H5" class="sapUiMediumMarginBottom"/>

                        <!-- RED -->
                        <VBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://circle-task-2"
                                       size="3.5rem"
                                       color="{= ${edit>/currentState} === 'RED' ? '#BB0000' : '#DEDEDE' }"
                                       press=".onSelectStateRed"
                                       tooltip="Disabled — chain will not run"
                                       class="sapUiPointer"/>
                            <Text text="Disabled" class="sapUiTinyMarginTop"/>
                        </VBox>

                        <!-- GREY (visual only) -->
                        <VBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://circle-task-2"
                                       size="3.5rem"
                                       color="#DEDEDE"/>
                            <Text text="On hold" class="sapUiTinyMarginTop"/>
                        </VBox>

                        <!-- GREEN -->
                        <VBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <core:Icon src="sap-icon://circle-task-2"
                                       size="3.5rem"
                                       color="{= ${edit>/currentState} === 'GREEN' ? '#107E3E' : '#DEDEDE' }"
                                       press=".onSelectStateGreen"
                                       tooltip="Ready — chain runs when green"
                                       class="sapUiPointer"/>
                            <Text text="Enable" class="sapUiTinyMarginTop"/>
                        </VBox>

                        <ObjectStatus
                            class="sapUiMediumMarginTop"
                            text="{= ${edit>/currentState} === 'GREEN' ? 'Ready to run' : 'Disabled' }"
                            state="{= ${edit>/currentState} === 'GREEN' ? 'Success' : 'Error' }"
                            icon="{= ${edit>/currentState} === 'GREEN' ? 'sap-icon://accept' : 'sap-icon://decline' }"/>
                    </VBox>
                </Panel>

                <!-- RIGHT: settings -->
                <Panel width="auto" class="sapUiSmallMargin">
                    <VBox class="sapUiMediumMarginTopBottom sapUiMediumMarginBeginEnd">
                        <Title text="Traffic Lights" level="H4" class="sapUiSmallMarginBottom"/>
                        <Title text="Settings" level="H5" class="sapUiMediumMarginBottom"/>

                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="Check every" width="9rem"/>
                            <SegmentedButton selectedKey="{edit>/checkInterval}" width="300px">
                                <items>
                                    <SegmentedButtonItem key="5"  text="5 min"/>
                                    <SegmentedButtonItem key="15" text="15 min" />
                                    <SegmentedButtonItem key="30" text="30 min" />
                                    <SegmentedButtonItem key="60" text="1 h"/>
                                </items>
                            </SegmentedButton>
                        </HBox>

                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="After run" width="9rem"/>
                            <Switch state="{edit>/autoReset}" class="sapUiTinyMarginEnd"/>
                            <Select selectedKey="{edit>/autoResetState}"
                                    visible="{edit>/autoReset}">
                                <core:Item key="GREY" text="⚪  On hold"/>
                                <core:Item key="RED"  text="🔴  Disabled"/>
                            </Select>
                        </HBox>

                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="Active" width="9rem"/>
                            <Switch state="{edit>/isActive}"/>
                        </HBox>

                        <Button text="Configure Step Parameters"
                                icon="sap-icon://settings"
                                type="Emphasized"
                                press=".onConfigureStepParameters"
                                class="sapUiLargeMarginTop"/>
                        <ObjectStatus
                            text="{edit>/stepParamsSummary}"
                            state="Success"
                            icon="sap-icon://accept"
                            visible="{= !!${edit>/stepParamsSummary} }"
                            class="sapUiTinyMarginTop"/>
                    </VBox>
                </Panel>

            </l:Splitter>
        </f:content>

        <f:footer>
            <OverflowToolbar>
                <Button text="{i18n>common.delete}" icon="sap-icon://delete"
                        type="Reject" press=".onDelete"
                        visible="{= !!${edit>/ID} }"/>
                <ToolbarSpacer/>
                <Button text="{i18n>common.cancel}" press=".onNavBack"/>
                <Button text="{i18n>common.save}" type="Emphasized" press=".onSave"/>
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>
