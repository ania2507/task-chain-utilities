<mvc:View
    controllerName="scheduler.controller.TrafficLightsPage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout">
    <f:DynamicPage id="trafficLightsPage" busy="{edit>/busy}"
                   toggleHeaderOnTitleClick="false" showFooter="true"
                   fitContent="true" preserveHeaderStateOnScroll="true">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center">
                        <Button icon="sap-icon://nav-back" type="Transparent"
                                tooltip="{i18n>common.back}" press=".onNavBack"
                                class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <Title text="{edit>/taskchain}" wrapping="true"/>
                            <Text text="{ path: 'edit>/name', formatter: '.formatBusinessName' }"/>
                        </VBox>
                    </HBox>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- STATUS BAR in header so it doesn't leave grey space below -->
        <f:header>
            <f:DynamicPageHeader pinnable="false">
                <HBox alignItems="Center" wrap="Wrap"
                      class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom">

                    <!-- Overall status (from technical table) -->
                    <HBox alignItems="Center" class="sapUiLargeMarginEnd">
                        <core:Icon
                            src="{= ${edit>/currentState} === 'GREEN' ? 'sap-icon://sys-enter-2' : ${edit>/currentState} === 'RED' ? 'sap-icon://sys-cancel-2' : 'sap-icon://synchronize' }"
                            size="2.5rem"
                            color="{= ${edit>/currentState} === 'GREEN' ? '#107E3E' : ${edit>/currentState} === 'RED' ? '#BB0000' : '#0a6ed1' }"
                            class="sapUiSmallMarginEnd"/>
                        <VBox>
                            <ObjectStatus
                                text="{= ${edit>/currentState} === 'GREEN' ? 'Ready to run' : ${edit>/currentState} === 'RED' ? 'Disabled' : 'Running' }"
                                state="{= ${edit>/currentState} === 'GREEN' ? 'Success' : ${edit>/currentState} === 'RED' ? 'Error' : 'Information' }"
                                inverted="true"
                                class="sapUiTinyMarginBottom"/>
                            <Text text="{= ${edit>/currentState} === 'GREEN' ? 'The task chain is enabled and active.' : ${edit>/currentState} === 'RED' ? 'On hold, waiting for a new ready status.' : 'The task chain is currently running.' }"/>
                        </VBox>
                    </HBox>

                    <core:HTML content="&lt;div style='width:1px;height:3.5rem;background:#e0e0e0;margin-right:1.5rem'&gt;&lt;/div&gt;"/>

                    <!-- Current state (from technical table) -->
                    <VBox class="sapUiMediumMarginEnd">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://lateness" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="Current state"/>
                        </HBox>
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://circle-task-2" size="0.875rem"
                                color="{= ${edit>/currentState} === 'GREEN' ? '#107E3E' : ${edit>/currentState} === 'RED' ? '#BB0000' : '#0a6ed1' }"
                                class="sapUiTinyMarginEnd"/>
                            <Text text="{= ${edit>/currentState} === 'GREEN' ? 'Enabled' : ${edit>/currentState} === 'RED' ? 'Disabled' : 'Running' }"/>
                        </HBox>
                    </VBox>

                    <!-- Monitoring interval -->
                    <VBox class="sapUiMediumMarginEnd">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://time-overtime" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="Monitoring interval"/>
                        </HBox>
                        <Text text="{= 'Every ' + (${edit>/checkInterval} === '60' ? '1 h' : ${edit>/checkInterval} + ' min') }"/>
                    </VBox>

                    <!-- After run -->
                    <VBox class="sapUiMediumMarginEnd">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://time-overtime" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="After run"/>
                        </HBox>
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://circle-task-2" size="0.875rem"
                                color="{= ${edit>/autoReset} ? (${edit>/autoResetState} === 'GREEN' ? '#107E3E' : '#BB0000') : '#DEDEDE' }"
                                class="sapUiTinyMarginEnd"/>
                            <Text text="{= ${edit>/autoReset} ? (${edit>/autoResetState} === 'GREEN' ? 'Enabled' : 'Disabled') : '—' }"/>
                        </HBox>
                    </VBox>

                    <!-- Next check -->
                    <VBox visible="{= !!${edit>/nextCheckIn} }">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <core:Icon src="sap-icon://process" size="0.875rem" class="sapUiTinyMarginEnd"/>
                            <Label text="Next check"/>
                        </HBox>
                        <Text text="{edit>/nextCheckIn}"/>
                    </VBox>

                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <l:Splitter class="splitter-auto-height">

                <!-- LEFT: Lifecycle -->
                <Panel class="sapUiNoMargin">
                    <layoutData>
                        <l:SplitterLayoutData size="310px" resizable="false"/>
                    </layoutData>
                    <VBox class="sapUiMediumMarginTopBottom sapUiMediumMarginBeginEnd">
                        <Title text="Lifecycle" level="H5" class="sapUiMediumMarginBottom"/>

                        <!-- Enabled -->
                        <HBox alignItems="Start" class="sapUiSmallMarginBottom">
                            <VBox alignItems="Center" width="2.5rem">
                                <core:Icon
                                    src="{= ${edit>/currentState} === 'GREEN' ? 'sap-icon://sys-enter-2' : 'sap-icon://circle-task-2' }"
                                    size="2rem"
                                    color="{= ${edit>/currentState} === 'GREEN' ? '#107E3E' : '#DEDEDE' }"
                                    press=".onSelectStateGreen"
                                    class="sapUiPointer"/>
                                <core:HTML content="&lt;div style='width:2px;height:1.5rem;background:#DEDEDE;margin-top:0.125rem'&gt;&lt;/div&gt;"/>
                            </VBox>
                            <VBox class="sapUiTinyMarginBegin">
                                <Title text="Enabled" level="H6"/>
                                <Text text="Task chain can be executed when triggered." wrapping="true"/>
                            </VBox>
                        </HBox>

                        <!-- Running -->
                        <HBox alignItems="Start" class="sapUiSmallMarginBottom">
                            <VBox alignItems="Center" width="2.5rem">
                                <core:Icon
                                    src="{= ${edit>/currentState} === 'GREY' ? 'sap-icon://synchronize' : 'sap-icon://circle-task-2' }"
                                    size="2rem"
                                    color="{= ${edit>/currentState} === 'GREY' ? '#0a6ed1' : '#DEDEDE' }"/>
                                <core:HTML content="&lt;div style='width:2px;height:1.5rem;background:#DEDEDE;margin-top:0.125rem'&gt;&lt;/div&gt;"/>
                            </VBox>
                            <VBox class="sapUiTinyMarginBegin">
                                <Title text="Running" level="H6"/>
                                <Text text="Task chain is currently running." wrapping="true"/>
                            </VBox>
                        </HBox>

                        <!-- Disabled -->
                        <HBox alignItems="Start" class="sapUiSmallMarginBottom">
                            <VBox alignItems="Center" width="2.5rem">
                                <core:Icon
                                    src="{= ${edit>/currentState} === 'RED' ? 'sap-icon://sys-cancel-2' : 'sap-icon://circle-task-2' }"
                                    size="2rem"
                                    color="{= ${edit>/currentState} === 'RED' ? '#BB0000' : '#DEDEDE' }"
                                    press=".onSelectStateRed"
                                    class="sapUiPointer"/>
                            </VBox>
                            <VBox class="sapUiTinyMarginBegin">
                                <Title text="Disabled" level="H6"/>
                                <Text text="Task chain execution is blocked." wrapping="true"/>
                            </VBox>
                        </HBox>

                    </VBox>
                </Panel>

                <!-- MIDDLE: Traffic Light Behavior -->
                <Panel class="sapUiNoMargin">
                    <VBox class="sapUiMediumMarginTopBottom sapUiMediumMarginBeginEnd">
                        <Title text="Traffic Light Behavior" level="H5"/>
                        <Text text="Configure how the traffic light status is monitored and updated."
                              class="sapUiSmallMarginTopBottom"/>

                        <!-- Monitoring interval -->
                        <VBox class="sapUiSmallMarginBottom">
                            <Title text="Monitoring interval" level="H6"/>
                            <Text text="How often the status is checked" class="sapUiTinyMarginBottom"/>
                            <SegmentedButton selectedKey="{edit>/checkInterval}">
                                <items>
                                    <SegmentedButtonItem key="5"  text="5 min"/>
                                    <SegmentedButtonItem key="15" text="15 min"/>
                                    <SegmentedButtonItem key="30" text="30 min"/>
                                    <SegmentedButtonItem key="60" text="1 h"/>
                                </items>
                            </SegmentedButton>
                        </VBox>

                        <!-- After each run -->
                        <VBox class="sapUiSmallMarginBottom">
                            <Title text="After each run" level="H6"/>
                            <Text text="Update traffic light status" class="sapUiTinyMarginBottom"/>
                            <HBox alignItems="Center">
                                <Switch state="{edit>/autoReset}" class="sapUiTinyMarginEnd"/>
                                <Select selectedKey="{edit>/autoResetState}" visible="{edit>/autoReset}">
                                    <core:Item key="GREEN" text="🟢  Enabled"/>
                                    <core:Item key="RED"   text="🔴  Disabled"/>
                                </Select>
                            </HBox>
                        </VBox>

                        <HBox class="sapUiSmallMarginTopBottom">
                            <MessageStrip
                                text="These settings will be applied at the next start of the task chain."
                                type="Information"
                                showIcon="true"
                                showCloseButton="false"/>
                        </HBox>

                        <Button text="Configure Step Parameters"
                                icon="sap-icon://settings"
                                type="Emphasized"
                                press=".onConfigureStepParameters"
                                class="sapUiSmallMarginTop"/>
                    </VBox>
                </Panel>

                <!-- RIGHT: Last Run -->
                <Panel class="sapUiNoMargin">
                    <layoutData>
                        <l:SplitterLayoutData size="280px" resizable="false"/>
                    </layoutData>
                    <VBox class="sapUiMediumMarginTopBottom sapUiMediumMarginBeginEnd">
                        <Title text="Last Run" level="H5" class="sapUiMediumMarginBottom"/>

                        <VBox visible="{= !!${edit>/lastRunAt} }">
                            <VBox class="sapUiSmallMarginBottom">
                                <Label text="Date and time" design="Bold"/>
                                <Text text="{ path: 'edit>/lastRunAt', formatter: '.formatDateTime' }"/>
                            </VBox>
                            <VBox>
                                <Label text="Status" design="Bold" class="sapUiTinyMarginBottom"/>
                                <HBox alignItems="Center">
                                    <core:Icon
                                        src="{= ${edit>/lastRunStatus} === 'completed' || ${edit>/lastRunStatus} === 'success' ? 'sap-icon://sys-enter-2' : ${edit>/lastRunStatus} === 'error' ? 'sap-icon://sys-cancel-2' : 'sap-icon://pending' }"
                                        size="1.25rem"
                                        color="{= ${edit>/lastRunStatus} === 'completed' || ${edit>/lastRunStatus} === 'success' ? '#107E3E' : ${edit>/lastRunStatus} === 'error' ? '#BB0000' : '#9E9E9E' }"
                                        class="sapUiTinyMarginEnd"/>
                                    <Text text="{edit>/lastRunStatus}"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <Text text="No runs yet." visible="{= !${edit>/lastRunAt} }"/>
                    </VBox>
                </Panel>

            </l:Splitter>
        </f:content>

        <f:footer>
            <OverflowToolbar>
                <Button text="{i18n>common.delete}" icon="sap-icon://delete"
                        type="Reject" press=".onDelete"
                        visible="{= !!${edit>/ID} }"/>
                <ToolbarSpacer/>
                <Button text="{i18n>common.cancel}" press=".onNavBack"/>
                <Button text="{i18n>common.save}" type="Emphasized" press=".onSave"/>
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>
